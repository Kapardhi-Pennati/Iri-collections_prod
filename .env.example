# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT VARIABLES (.env.production)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to your production server as `.env` and fill in the real values.

# ─── Core Django Settings ──────────────────────────────────────────────────
# REQUIRED: Generate a new secret key for production and never share it.
# (You can generate one using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=replace-with-a-secure-production-secret-key

# MUST BE FALSE IN PRODUCTION
DEBUG=False

# Your production domains (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ─── Database & Caching ────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@hostname:5432/db_name

# Redis connection string (for Celery and cache)
REDIS_URL=redis://127.0.0.1:6379/1

# ─── Security & HTTPS ──────────────────────────────────────────────────────
# Ensure HTTPS is enforced
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Strict Transport Security (HSTS)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ─── CORS & CSRF Origins ───────────────────────────────────────────────────
# Replace with your actual frontend domain if hosted separately
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ─── Cloud SMTP Email Configuration ────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-cloud-smtp-api-key
DEFAULT_FROM_EMAIL=sales@yourdomain.com

# ─── PhonePe Payments ─────────────────────────────────────────────────────
# Obtain from: https://dashboard.phonepe.com/ → API Keys
# Use UAT (sandbox) credentials during development and testing
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1

# Optional explicit Celery endpoints (defaults are set in settings.py)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ─── Frontend & Application Links ──────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
